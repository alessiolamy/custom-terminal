# .streamlit/secrets.toml
# ⚠️  NEVER commit this file to GitHub!
# Add it to .gitignore — store real secrets in GitHub Actions secrets.
#
# For Streamlit Cloud: paste these in the Secrets section of the dashboard.
# For local dev: fill in below and run: streamlit run app.py

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate password hash:
#   python -c "import hashlib; print(hashlib.sha256(b'YOUR_PASSWORD').hexdigest())"
APP_PASSWORD_HASH = "REPLACE_WITH_SHA256_OF_YOUR_PASSWORD"

# Generate TOTP secret:
#   python -c "import pyotp; print(pyotp.random_base32())"
# Then scan the QR into Google Authenticator / Authy:
#   python -c "import pyotp; print(pyotp.totp.TOTP('YOUR_SECRET').provisioning_uri('Me','Terminal'))"
TOTP_SECRET = "REPLACE_WITH_BASE32_TOTP_SECRET"

# ── API Keys ───────────────────────────────────────────────────────────────────
FRED_API_KEY      = "YOUR_FRED_KEY_HERE"          # Already have this ✓
NEWS_API_KEY      = ""                             # newsapi.org — free tier
POLYGON_API_KEY   = ""                             # polygon.io — free tier
ALPHA_VANTAGE_KEY = ""                             # alphavantage.co — free
FMP_API_KEY       = ""                             # financialmodelingprep.com — free tier
TRADIER_KEY       = ""                             # tradier.com — free sandbox
